@@ -0,0 +1,68 @@
+import {Button} from '@sanity/ui'
+import {useCallback, useEffect, useMemo, useRef} from 'react'
+import {useDispatch} from 'react-redux'
+
+import {inputs} from '../../config/searchFacets'
+import useTypedSelector from '../../hooks/useTypedSelector'
+import {searchActions} from '../../modules/search'
+
+const STORAGE_KEY = 'sanity-plugin-media.showUnusedOnly'
+
+function isUnusedOnlyFacet(
+  facet: {name: string; operatorType: string; value: unknown} | undefined
+): boolean {
+  return facet?.name === 'inUse' && facet.operatorType === 'is' && facet.value === 'false'
+}
+
+export default function UnusedAssetsToggle() {
+  const dispatch = useDispatch()
+  const facets = useTypedSelector(state => state.search.facets)
+  const inUseFacet = useMemo(() => facets.find(facet => facet.name === 'inUse'), [facets])
+  const unusedOnly = isUnusedOnlyFacet(inUseFacet)
+  const restoredPreference = useRef(false)
+
+  const setUnusedOnly = useCallback(
+    (enabled: boolean) => {
+      dispatch(searchActions.facetsRemoveByName({facetName: 'inUse'}))
+
+      if (enabled) {
+        dispatch(
+          searchActions.facetsAdd({
+            facet: {
+              ...inputs.inUse,
+              operatorType: 'is',
+              value: 'false'
+            }
+          })
+        )
+      }
+
+      if (typeof window !== 'undefined') {
+        window.localStorage.setItem(STORAGE_KEY, enabled ? '1' : '0')
+      }
+    },
+    [dispatch]
+  )
+
+  useEffect(() => {
+    if (restoredPreference.current || typeof window === 'undefined') {
+      return
+    }
+
+    restoredPreference.current = true
+
+    if (window.localStorage.getItem(STORAGE_KEY) === '1' && !isUnusedOnlyFacet(inUseFacet)) {
+      setUnusedOnly(true)
+    }
+  }, [inUseFacet, setUnusedOnly])
+
+  return (
+    <Button
+      fontSize={1}
+      mode={unusedOnly ? 'default' : 'ghost'}
+      onClick={() => setUnusedOnly(!unusedOnly)}
+      text="Asset not in use"
+      tone={unusedOnly ? 'primary' : 'default'}
+    />
+  )
+}
